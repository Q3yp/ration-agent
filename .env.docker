# =============================================================================
# Ration Agent Docker Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values for Docker deployment

# =============================================================================
# Required Configuration - MUST BE SET
# =============================================================================

# JWT Secret for Authentication (REQUIRED - generate a strong 32+ character secret)
JWT_SECRET=your_super_secret_jwt_key_here_32_chars_minimum

# Database Password (REQUIRED - use a strong secure password)
POSTGRES_PASSWORD=your_secure_database_password_here

# AI Model Configuration (REQUIRED)
# =============================================================================
OPENAI_ENDPOINT="https://openrouter.ai/api/v1"
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# Alternative providers (uncomment to use):
# For DeepSeek direct API:
# OPENAI_ENDPOINT="https://api.deepseek.com/v1"
# OPENROUTER_API_KEY=your_deepseek_api_key_here
# OPENROUTER_MODEL=deepseek-chat

# =============================================================================
# Model Configuration for Different Agent Nodes (Optional)
# =============================================================================
# Nutritionist (Supervisor) - Requires reasoning capabilities
NUTRITIONIST_MODEL=anthropic/claude-sonnet-4

# Researcher - Good for web search and information gathering
RESEARCHER_MODEL=google/gemini-2.5-flash

# Coder - Needs strong coding capabilities
CODER_MODEL=anthropic/claude-sonnet-4

# Title Generation - Lightweight model for simple tasks
TITLE_GENERATION_MODEL=google/gemini-2.5-flash-lite

# Alternative: Use same model for all agents (uncomment to use)
# NUTRITIONIST_MODEL=deepseek/deepseek-chat-v3-0324:free
# RESEARCHER_MODEL=deepseek/deepseek-chat-v3-0324:free
# CODER_MODEL=deepseek/deepseek-chat-v3-0324:free
# TITLE_GENERATION_MODEL=deepseek/deepseek-chat-v3-0324:free

# =============================================================================
# Agent Temperature Settings (Optional)
# =============================================================================
SUPERVISOR_TEMPERATURE=0.7
RESEARCHER_TEMPERATURE=0
CODER_TEMPERATURE=0.7
TITLE_GENERATION_TEMPERATURE=0.3

# =============================================================================
# LangGraph Configuration (Optional)
# =============================================================================
LANGGRAPH_RECURSION_LIMIT=500

# =============================================================================
# PostgreSQL Configuration (Auto-configured for Docker)
# =============================================================================
# These settings are optimized for docker-compose deployment
# Backend connects to postgres service via internal Docker network
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ration_agent
POSTGRES_USER=ration_user
CHAT_HISTORY_TABLE=chat_history

# Note: External database access from host machine uses port 5433

# =============================================================================
# LangSmith Configuration (Optional - for debugging and monitoring)
# =============================================================================
# Enable tracing and monitoring with LangSmith
LANGSMITH_TRACING="false"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="your_langsmith_api_key_here"
LANGSMITH_PROJECT="ration-agent-docker"
