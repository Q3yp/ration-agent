
# =============================================================================
# Ration Agent Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# Required variables will cause the app to fail on startup if missing.

# JWT Secret (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=your_generated_jwt_secret_here

# Admin Password (REQUIRED for first run / admin user creation)
ADMIN_PASSWORD=your_secure_admin_password_here

# AI Model Configuration
# =============================================================================
OPENAI_ENDPOINT="https://openrouter.ai/api/v1"
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# Google OAuth Configuration
# =============================================================================
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id

# Alternative providers (uncomment to use):
# For DeepSeek direct API:
# OPENAI_ENDPOINT="https://api.deepseek.com/v1"
# OPENROUTER_API_KEY=your_deepseek_api_key_here
# OPENROUTER_MODEL=deepseek-chat

# LangGraph Configuration
# =============================================================================
LANGGRAPH_RECURSION_LIMIT=500

# Model Configuration for Different Agent Nodes
# =============================================================================
# Nutritionist (Supervisor) - Requires reasoning capabilities
NUTRITIONIST_MODEL=anthropic/claude-sonnet-4

# Researcher - Good for web search and information gathering
RESEARCHER_MODEL=google/gemini-2.5-flash

# Coder - Needs strong coding capabilities
CODER_MODEL=anthropic/claude-sonnet-4

# Title Generation - Lightweight model for simple tasks
TITLE_GENERATION_MODEL=google/gemini-2.5-flash-lite

# Alternative: Use same model for all agents
# NUTRITIONIST_MODEL=deepseek-chat
# RESEARCHER_MODEL=deepseek-chat
# CODER_MODEL=deepseek-chat
# TITLE_GENERATION_MODEL=deepseek-chat

# Agent Temperature Settings
# =============================================================================
SUPERVISOR_TEMPERATURE=0.7
RESEARCHER_TEMPERATURE=0
CODER_TEMPERATURE=0.7
TITLE_GENERATION_TEMPERATURE=0.3

# PostgreSQL Configuration
# =============================================================================
# Database connection settings for chat history persistence
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=ration_agent
POSTGRES_USER=ration_user
POSTGRES_PASSWORD=your_secure_password_here
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=100

# LangSmith Configuration (Optional)
# =============================================================================
# Enable tracing and monitoring with LangSmith
LANGSMITH_TRACING="false"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="your_langsmith_api_key_here"
LANGSMITH_PROJECT="your_project_name"

# SMS Provider (Ihuyi) Configuration
# =============================================================================
IHUYI_SMS_ACCOUNT=your_ihuyi_api_id
IHUYI_SMS_PASSWORD=your_ihuyi_api_key
IHUYI_SMS_TEMPLATE_ID=320655
SMS_CODE_TTL_SECONDS=600
SMS_CODE_RESEND_INTERVAL_SECONDS=60
SMS_CODE_DAILY_LIMIT=20
SMS_HTTP_TIMEOUT=10
